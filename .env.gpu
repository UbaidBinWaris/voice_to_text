# Production GPU Server Configuration (Vast.ai RTX 4090)
# Copy this file to .env on your Vast.ai GPU instance!

# Ollama API URL on GPU Server (or SSH tunnel URL)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen3.5:35b

# STT (Faster-Whisper GPU Settings)
# High Accuracy CTranslate2 Models:
# - Systran/faster-distil-whisper-medium.en (Fastest & Accurate distil model)
# - small.en (Lightweight & fast)
# - medium.en (High accuracy)
# - large-v3-turbo (State of the art accuracy & high speed)
WHISPER_MODEL=Systran/faster-distil-whisper-medium.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# TTS (Piper Settings)
PIPER_MODEL=piper_models/en_US-ryan-high.onnx

# VAD & Audio Performance Tuning
SAMPLE_RATE=16000
MAX_RESPONSE_WORDS=20
VAD_AGGRESSIVENESS=3
SILENCE_DURATION_SEC=0.4
